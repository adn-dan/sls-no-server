<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme_title"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:layout_marginBottom="16dp" />

        <!-- Brand selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme_color"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_brand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/default_theme"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_default" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/lastfm_theme"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_prefix_last_fm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/librefm_theme"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_prefix_libre_fm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/listenbrainz_theme"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_prefix_listenbrainz" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Dark mode selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme_mode"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mode_light"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_light" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mode_dark"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_dark" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mode_system"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_system" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Keep legacy hidden radio buttons for backward compat (not shown to user) -->
        <RadioGroup
            android:id="@+id/legacy_radio_group"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone">
            <RadioButton android:id="@+id/default_theme_dark" />
            <RadioButton android:id="@+id/lastfm_theme_dark" />
            <RadioButton android:id="@+id/librefm_theme_dark" />
            <RadioButton android:id="@+id/listenbrainz_theme_dark" />
        </RadioGroup>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
